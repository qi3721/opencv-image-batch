import cv2
import glob

images = sorted(glob.glob("yiyout/sige*.jpg"))

for i, img_path in enumerate(images):
    img = cv2.imread(img_path)
    if img is not None:
        img = cv2.resize(img, (0, 0), fx=0.5, fy=0.5)
        cv2.imshow(f"img_{i}", img)
        cv2.waitKey(500)
    else:
        print(f"无法读取: {img_path}")

cv2.destroyAllWindows()